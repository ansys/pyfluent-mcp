# ============================================================================
# ansys-fluent-mcp - example configuration
# ============================================================================
# Copy this file to ".env" (or set these as real environment variables).
# All settings are optional.

# ============================================================================
# SERVER OPTIONS
# ============================================================================
# FLUIDS_MCP_LOG_LEVEL=INFO
# FLUIDS_MCP_SETTINGS_JSON=<path-to-custom-settings-schema>
# FLUIDS_MCP_MAX_STEPS=30
# FLUIDS_MCP_DISABLE_SESSION_LOGS=0

# ============================================================================
# NETWORK + TLS OPTIONS
# ============================================================================
# FLUIDS_MCP_HTTP_TIMEOUT=60
# FLUIDS_MCP_CA_BUNDLE=/path/to/corporate-ca.pem
# FLUIDS_MCP_VERIFY_TLS=1
