# ============================================================================
# ansys-fluent-mcp — example configuration
# ============================================================================
# Copy this file to ".env" (or set these as real environment variables) and
# fill in the <...> placeholders. All settings are OPTIONAL; the LLM block
# below is only needed for the AI-assisted features (codegen / clarify).
#
# You only need ONE of the LLM scenarios. Pick the block that matches what
# you have, uncomment its lines, and ignore the rest. Switching model or
# provider later is just editing these values and restarting — no code.
# ----------------------------------------------------------------------------

# ============================================================================
# 1. CHOOSE YOUR AI MODEL  (pick exactly one block)
# ============================================================================

# --- Option A: OpenAI -------------------------------------------------------
# Needs: pip install ansys-fluent-mcp[providers]
# OPENAI_API_KEY=<your-openai-key>
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# --- Option B: Anthropic (Claude) ------------------------------------------
# Needs: pip install ansys-fluent-mcp[providers]
# ANTHROPIC_API_KEY=<your-anthropic-key>
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet

# --- Option C: Google Gemini -----------------------------------------------
# Needs: pip install ansys-fluent-mcp[providers]
# GEMINI_API_KEY=<your-gemini-key>
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-pro

# --- Option D: A URL + key from your organization --------------------------
# (Azure OpenAI, or any OpenAI-compatible gateway such as vLLM / Ollama.)
# No extra install needed — this uses the built-in HTTP path.
# LLM_ENDPOINT=<the-url-you-were-given>
# LLM_API_KEY=<your-key>
# LLM_MODEL=gpt-4o
# LLM_AUTH_STYLE=azure-api-key      # only if your Azure resource needs it

# --- Option E: Azure OpenAI via the NATIVE connector (advanced) -------------
# Needs: pip install ansys-fluent-mcp[providers]
# LLM_TRANSPORT=litellm
# LLM_MODEL=gpt-4o                  # = your Azure deployment name
# AZURE_API_KEY=<your-azure-key>
# AZURE_API_BASE=https://<resource>.openai.azure.com
# AZURE_API_VERSION=2024-08-01-preview

# ============================================================================
# 2. OPTIONAL LLM FINE-TUNING  (sensible defaults; most users skip this)
# ============================================================================
# LLM_TRANSPORT=auto                # auto | litellm | openai_compat
# LLM_CACHE_MECHANISM=auto          # openai_auto | anthropic_cache_control | gemini_context | none
# LLM_CACHE_TTL_SECONDS=            # cache TTL hint (per-provider default)
# LLM_SEND_CACHE_KEY=1              # 0 to disable the cache routing hint
# LLM_MAX_TOKENS_PARAM=auto         # auto-handles gpt-5 / o-series
# LLM_SEND_TEMPERATURE=auto         # auto-off for gpt-5 / o-series
# LLM_MAX_RETRIES=3
# LLM_TIMEOUT_SECONDS=60

# --- TLS + network egress (secure by default) ------------------------------
# TLS verification is ON by default. To trust a corporate / self-signed CA,
# set LLM_CA_BUNDLE to your PEM bundle (do NOT disable verification).
# LLM_CA_BUNDLE=/path/to/corporate-ca.pem
# LLM_TLS_INSECURE=0                # 1 disables TLS verification (dev only; unsafe)
# FLUIDS_AGENT_OFFLINE=0           # 1 = forbid ALL outbound LLM / retrieval calls
# FLUIDS_AGENT_ALLOWED_LLM_HOSTS=  # comma-separated egress host allowlist

# ============================================================================
# 3. SERVER OPTIONS  (optional)
# ============================================================================
# FLUIDS_MCP_LOG_LEVEL=INFO
# FLUIDS_MCP_SETTINGS_JSON=<path-to-custom-settings-schema>
# FLUIDS_MCP_LLM_MAX_STEPS=30
# FLUIDS_MCP_DISABLE_SESSION_LOGS=0
